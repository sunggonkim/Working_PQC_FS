      ],
      "returncode": 0,
      "stdout": "artifacts/validation/tpm_pcr_policy_probe/flush_good.stdout.txt",
      "stderr": "artifacts/validation/tpm_pcr_policy_probe/flush_good.stderr.txt"
    },
    {
