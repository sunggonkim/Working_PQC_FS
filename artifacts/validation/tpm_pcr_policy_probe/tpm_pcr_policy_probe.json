        "-S",
        "chown",
        "1000:1000",
        "/tmp/aegis_tpm_pcr_4snll8ib/unsealed.dat"
      ],
      "returncode": 0,
      "stdout": "artifacts/validation/tpm_pcr_policy_probe/chown_unsealed.stdout.txt",
      "stderr": "artifacts/validation/tpm_pcr_policy_probe/chown_unsealed.stderr.txt"
    },
    {
      "name": "flush_good",
      "command": [
