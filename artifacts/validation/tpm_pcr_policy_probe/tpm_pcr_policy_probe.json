        "-l",
        "sha256:0,1,2,3",
        "-f",
        "pcr.bin"
      ],
      "returncode": 0,
      "stdout": "artifacts/validation/tpm_pcr_policy_probe/policypcr_current.stdout.txt",
      "stderr": "artifacts/validation/tpm_pcr_policy_probe/policypcr_current.stderr.txt"
    },
    {
      "name": "unseal_current",
      "command": [
        "sudo",
        "-S",
        "tpm2_unseal",
        "-c",
        "seal.ctx",
        "-p",
        "session:good.sess",
        "-o",
        "unsealed.dat"
      ],
      "returncode": 0,
      "stdout": "artifacts/validation/tpm_pcr_policy_probe/unseal_current.stdout.txt",
      "stderr": "artifacts/validation/tpm_pcr_policy_probe/unseal_current.stderr.txt"
