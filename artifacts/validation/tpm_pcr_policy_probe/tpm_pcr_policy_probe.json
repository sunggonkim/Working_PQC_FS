        "-S",
        "drift.sess",
        "-l",
        "sha256:0,1,2,3",
        "-f",
        "pcr_drift.bin"
      ],
      "returncode": 1,
      "stdout": "artifacts/validation/tpm_pcr_policy_probe/policypcr_drift.stdout.txt",
      "stderr": "artifacts/validation/tpm_pcr_policy_probe/policypcr_drift.stderr.txt"
